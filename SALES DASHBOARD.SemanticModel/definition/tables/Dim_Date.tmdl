	partition Dim_Date = calculated
		mode: import
		source = ```
				
				VAR _StartDate = DATE(2018, 1, 1)
				VAR _EndDate = DATE(2022, 12, 31)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(_StartDate, _EndDate),
				    "Year",             YEAR([Date]),
				    "Quarter",          QUARTER([Date]),
				    "Month Number",     MONTH([Date]),
				    "Month Name",      FORMAT([Date], "MMM"),
				    "Day",              DAY([Date]) 
				)
				```

